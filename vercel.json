{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "api/index.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "excludeFiles": "{backend/tests/**,frontend/**,**/__pycache__/**,**/*.pyc,.pytest_cache/**}"
    }
  }
}
